---
---
<div id="home" style="scroll-margin-top: 0;">
  <div class="flex flex-col justify-center h-screen px-[8vw] max-[768px]:px-6 max-[768px]:justify-end max-[768px]:pb-20">

    <!-- Overline label -->
    <p class="hero-pre text-eldion-cyan text-[0.72rem] font-semibold tracking-[0.24em] uppercase mb-6 max-[768px]:mb-5">
      <span data-i18n="no">Batteriløs industriell IoT</span><span data-i18n="en">Battery-free industrial IoT</span>
    </p>

    <!-- Main heading – intentionally restrained so subtitle can breathe -->
    <h1 class="hero-heading font-inter font-bold text-white/90 leading-[1.08] tracking-[-0.022em] m-0
               text-[clamp(1.85rem,3.6vw,3.2rem)] max-w-[540px] max-[768px]:max-w-none">
      <span class="hero-line-wrap"><span class="hero-line"><span data-i18n="no">Vi gjør</span><span data-i18n="en">We make</span></span></span>
      <span class="hero-line-wrap"><span class="hero-line"><span data-i18n="no">industrien</span><span data-i18n="en">industry</span></span></span>
      <span class="hero-line-wrap"><span class="hero-line"><span data-i18n="no">trådløs.</span><span data-i18n="en">wireless.</span></span></span>
    </h1>

    <!-- Subtitle – the real hero message -->
    <div class="hero-sub mt-7 max-w-[520px] max-[768px]:max-w-none max-[768px]:mt-5">
      <p class="text-white/60 text-[clamp(1.05rem,1.65vw,1.45rem)] leading-[1.6] m-0">
        <span data-i18n="no">Trådløs data drevet av spillvarme.</span><span data-i18n="en">Wireless data powered by waste heat.</span>
      </p>
      <p class="text-[clamp(1.05rem,1.65vw,1.45rem)] leading-[1.6] font-semibold m-0 hero-gradient-text">
        <span data-i18n="no">Ingen batterier. Ingen kabler.</span><span data-i18n="en">No batteries. No cables.</span>
      </p>
    </div>

    <!-- CTA -->
    <div class="hero-cta mt-9 max-[768px]:mt-8 flex flex-wrap items-center gap-3">
      <a
        href="#contact"
        class="magnetic inline-flex items-center gap-2 font-inter font-semibold text-[0.95rem]
               no-underline text-white bg-eldion-cyan
               px-6 py-[13px] rounded-full
               transition-all duration-300
               hover:brightness-110 hover:-translate-y-[2px]"
      >
        <span data-i18n="no">Kontakt oss</span><span data-i18n="en">Contact us</span>
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
      <a
        href="#goal"
        class="magnetic inline-flex items-center gap-2 text-eldion-cyan font-inter font-semibold text-[0.95rem]
               no-underline bg-white/[0.07] backdrop-blur-sm border border-white/[0.14]
               px-6 py-[13px] rounded-full
               transition-all duration-300
               hover:bg-eldion-cyan/[0.14] hover:border-eldion-cyan/50 hover:-translate-y-[2px]"
      >
        <span data-i18n="no">Finn ut mer</span><span data-i18n="en">Learn more</span>
        <i data-lucide="chevron-down" class="w-4 h-4"></i>
      </a>
    </div>

  </div>
</div>
