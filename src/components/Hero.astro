---
---
<div id="home" style="scroll-margin-top: 0;">
  <div class="flex flex-col justify-center h-screen px-[8vw] max-[768px]:px-6 max-[768px]:justify-end max-[768px]:pb-20">

    <!-- Overline label -->
    <p class="hero-pre text-eldion-cyan text-[0.72rem] font-semibold tracking-[0.24em] uppercase mb-6 max-[768px]:mb-5">
      Batteriløs industriell IoT
    </p>

    <!-- Main heading – intentionally restrained so subtitle can breathe -->
    <h1 class="hero-heading font-inter font-bold text-white/90 leading-[1.08] tracking-[-0.022em] m-0
               text-[clamp(1.85rem,3.6vw,3.2rem)] max-w-[540px] max-[768px]:max-w-none">
      <span class="hero-line-wrap"><span class="hero-line">Vi gjør</span></span>
      <span class="hero-line-wrap"><span class="hero-line">industrien</span></span>
      <span class="hero-line-wrap"><span class="hero-line">trådløs.</span></span>
    </h1>

    <!-- Subtitle – the real hero message -->
    <div class="hero-sub mt-7 max-w-[520px] max-[768px]:max-w-none max-[768px]:mt-5">
      <p class="text-white/60 text-[clamp(1.05rem,1.65vw,1.45rem)] leading-[1.6] m-0">
        Trådløs data drevet av spillvarme.
      </p>
      <p class="text-[clamp(1.05rem,1.65vw,1.45rem)] leading-[1.6] font-semibold m-0 hero-gradient-text">
        Ingen batterier. Ingen kabler.
      </p>
    </div>

    <!-- CTA -->
    <div class="hero-cta mt-9 max-[768px]:mt-8">
      <a
        href="#goal"
        class="magnetic inline-flex items-center gap-3 text-eldion-cyan font-inter font-semibold text-[0.95rem]
               no-underline bg-white/[0.07] backdrop-blur-sm border border-white/[0.14]
               px-6 py-[13px] rounded-full
               transition-all duration-300
               hover:bg-eldion-cyan/[0.14] hover:border-eldion-cyan/50 hover:-translate-y-[2px]"
      >
        Finn ut mer
        <i data-lucide="chevron-down" class="w-4 h-4"></i>
      </a>
    </div>

  </div>
</div>
