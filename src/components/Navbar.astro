---
const links = [
  { href: '#goal',    label: 'Løsningen' },
  { href: '#team',    label: 'Om oss' },
  { href: '#news',    label: 'Nyheter' },
  { href: '#contact', label: 'Kontakt oss' },
];
---
<header
  id="site-header"
  class="fixed top-0 w-full z-50 flex flex-wrap items-center justify-between
         bg-black/45 backdrop-blur-md shadow-[0_2px_5px_rgba(0,0,0,0.4)]
         box-border px-[clamp(10px,4vw,60px)] py-[10px]
         transition-all duration-300
         max-[900px]:flex-col max-[900px]:items-start"
>
  <div class="flex items-center gap-2 flex-none min-w-[200px]">
    <a href="#home">
      <img
        id="nav-logo"
        src="/images/ny_logo.png"
        alt="eldION logo"
        style="width:250px;height:auto;transition:width 0.3s ease;
               filter:drop-shadow(0 6px 28px rgba(0,0,0,0.95)) drop-shadow(0 2px 10px rgba(0,0,0,0.8));"
      />
    </a>
  </div>

  <nav class="flex flex-wrap justify-end gap-[clamp(10px,2vw,30px)] flex-1 min-w-[200px] text-right max-[900px]:justify-center max-[900px]:w-full max-[900px]:mt-[10px]">
    {links.map(({ href, label }) => (
      <a
        href={href}
        class="text-white no-underline font-medium whitespace-nowrap inline-block transition-all duration-200 hover:text-cyan-bright hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-bright focus-visible:outline-offset-2 focus-visible:rounded focus-visible:text-cyan-bright"
      >
        {label}
      </a>
    ))}
  </nav>
</header>

<script>
  const hdr  = document.getElementById('site-header') as HTMLElement | null;
  const logo = document.getElementById('nav-logo')    as HTMLImageElement | null;

  function updateNav() {
    const scrolled = window.scrollY > 60;
    if (!hdr || !logo) return;
    hdr.style.paddingTop      = scrolled ? '5px'              : '';
    hdr.style.paddingBottom   = scrolled ? '5px'              : '';
    hdr.style.backgroundColor = scrolled ? 'rgba(0,0,0,0.75)' : '';
    logo.style.width          = scrolled ? '175px'            : '250px';
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
