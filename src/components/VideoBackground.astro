---
---
<!-- Full-screen video layer -->
<video
  id="bg-video"
  autoplay muted loop playsinline preload="auto"
  aria-hidden="true"
  style="position:fixed;inset:0;width:100%;height:100%;object-fit:cover;z-index:-2;"
>
  <source src="/images/backdropvideo.mp4" type="video/mp4" />
</video>

<!-- Loop-fade overlay: fades to black at the loop point to hide the jump.
     Sits between video (z:-2) and vignette (z:-1) in DOM order so
     vignette renders on top of it. -->
<div
  id="bg-loop-fade"
  aria-hidden="true"
  style="position:fixed;inset:0;z-index:-1;background:#000;opacity:0;pointer-events:none;"
></div>

<!-- Radial vignette overlay: subtly clear at centre → near-black at edges -->
<div
  aria-hidden="true"
  style="
    position:fixed;inset:0;z-index:-1;
    background: radial-gradient(
      ellipse at 50% 46%,
      rgba(0,0,0,0.32) 0%,
      rgba(0,0,0,0.68) 52%,
      rgba(0,0,0,0.93) 100%
    );
  "
></div>

<script>
  const vid    = document.getElementById('bg-video')     as HTMLVideoElement | null;
  const fadeEl = document.getElementById('bg-loop-fade') as HTMLElement | null;
  if (!vid) throw new Error('bg-video not found');

  vid.playbackRate = 1;
  vid.addEventListener('canplay', () => { vid.playbackRate = 1; }, { once: true });

  /* ── Stall / freeze recovery ──────────────────────────────────────
     Browsers can stall background videos on slow connections or after
     the tab has been hidden. We detect this and force a reload.      */

  let stallTimer: ReturnType<typeof setTimeout> | null = null;

  function recover() {
    vid.load();
    vid.play().catch(() => {});
  }

  vid.addEventListener('stalled', recover);

  vid.addEventListener('waiting', () => {
    stallTimer = setTimeout(recover, 3000);
  });
  vid.addEventListener('playing', () => {
    if (stallTimer) { clearTimeout(stallTimer); stallTimer = null; }
    vid.playbackRate = 1;
  });

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible' && vid.paused) {
      vid.play().catch(() => {});
    }
  });

  setInterval(() => {
    if (vid.paused && document.visibilityState === 'visible') {
      vid.play().catch(() => {});
    }
  }, 5000);

  /* ── Loop-point fade ──────────────────────────────────────────────
     Start darkening 0.8 s before the end, reach full black at the
     loop point, then fade back over 0.45 s. The overlap hides the
     visual jump. Uses rAF so the curve is smooth at 60 fps.          */

  const FADE_OUT = 0.8;  // seconds before end to begin fading out
  const FADE_IN  = 0.45; // seconds after loop start to finish fading in

  function loopFadeTick() {
    if (fadeEl && vid.duration && isFinite(vid.duration) && !vid.paused) {
      const timeLeft = vid.duration - vid.currentTime;
      const timeIn   = vid.currentTime;

      let opacity = 0;
      if (timeLeft < FADE_OUT) {
        opacity = 1 - (timeLeft / FADE_OUT);       // 0 → 1 as end approaches
      } else if (timeIn < FADE_IN) {
        opacity = 1 - (timeIn   / FADE_IN);        // 1 → 0 after loop restarts
      }

      fadeEl.style.opacity = opacity.toFixed(3);
    }
    requestAnimationFrame(loopFadeTick);
  }

  loopFadeTick();
</script>
