---
<!-- Full-screen video layer — driven by scroll position, no autoplay loop -->
<video
  id="bg-video"
  muted playsinline preload="auto"
  aria-hidden="true"
  style="position:fixed;inset:0;width:100%;height:100%;object-fit:cover;z-index:-2;"
>
  <source src="/images/backdropvideo.mp4" type="video/mp4" />
</video>

<!-- Radial vignette overlay: subtly clear at centre → near-black at edges -->
<div
  aria-hidden="true"
  style="
    position:fixed;inset:0;z-index:-1;
    background: radial-gradient(
      ellipse at 50% 46%,
      rgba(0,0,0,0.32) 0%,
      rgba(0,0,0,0.68) 52%,
      rgba(0,0,0,0.93) 100%
    );
  "
></div>

<script>
  const vid = document.getElementById('bg-video') as HTMLVideoElement | null;
  if (!vid) throw new Error('bg-video not found');

  /* Scroll-driven playback:
     scroll position (0 → bottom) maps to video time (0 → duration).
     Scrolling down advances the video; scrolling up rewinds it.
     No autoplay, no loop — the loop-jump issue disappears entirely. */

  vid.pause();

  function seekToScroll() {
    if (!vid.duration || !isFinite(vid.duration)) return;
    const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
    if (maxScroll > 0) {
      vid.currentTime = (window.scrollY / maxScroll) * vid.duration;
    }
  }

  /* Seek as soon as duration is known, and on every scroll (rAF-throttled) */
  vid.addEventListener('loadedmetadata', seekToScroll);

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(() => { seekToScroll(); ticking = false; });
    }
  }, { passive: true });

  /* Re-sync when tab becomes visible after being hidden */
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') seekToScroll();
  });
</script>
