---
interface Props {
  date: string;
  dateEn: string;
  logo: string;
  logoAlt: string;
  title: string;
  titleEn: string;
  content: string;
  contentEn: string;
  logoStyle?: string;
  side?: 'left' | 'right';
}
const {
  date, dateEn, logo, logoAlt, title, titleEn, content, contentEn,
  logoStyle = '', side = 'left',
} = Astro.props;
const isLeft = side === 'left';
---
<div class={`timeline-item tl-${side}`}>
  <div class={`tl-card ${isLeft ? 'text-right max-[768px]:text-left' : 'text-left'}`}>
    <img
      src={`/images/${logo}`}
      alt={logoAlt}
      class={`tl-logo ${isLeft ? 'ml-auto max-[768px]:ml-0' : ''} ${logoStyle}`}
    />
    <span class="block text-[0.6rem] font-bold text-cyan-400 uppercase tracking-[0.22em] mb-2.5">
      <span data-i18n="no">{date}</span><span data-i18n="en">{dateEn}</span>
    </span>
    <h3 class="font-comfortaa text-[1.08rem] font-semibold text-white/95 mb-2.5 leading-snug tracking-tight">
      <span data-i18n="no">{title}</span><span data-i18n="en">{titleEn}</span>
    </h3>
    <p class="text-[0.83rem] text-white/52 leading-relaxed">
      <span data-i18n="no">{content}</span><span data-i18n="en">{contentEn}</span>
    </p>
  </div>
</div>
