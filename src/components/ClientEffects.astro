<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const isReduced = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
  const isTouch   = window.matchMedia('(hover:none) and (pointer:coarse)').matches;
  const isMobile  = window.matchMedia('(max-width: 768px)').matches;

  /* ══════════════════════════════════════════════════════════════
     1. INITIAL HIDE – all GSAP-owned elements start invisible
     ══════════════════════════════════════════════════════════════ */
  gsap.set('.gsap-card', { opacity: 0, y: 32 });
  /* .timeline-item opacity:0 is handled by CSS; GSAP fromTo overrides it */

  /* ══════════════════════════════════════════════════════════════
     2. HERO TEXT REVEAL  (load-time, not scroll)
        CSS sets initial hidden state; GSAP animates to visible
     ══════════════════════════════════════════════════════════════ */
  if (!isReduced) {
    const heroTl = gsap.timeline({ delay: 0.22 });
    heroTl
      .to('.hero-pre',  { opacity: 1, duration: 0.6,  ease: 'power3.out' })
      .to('.hero-line', { y: 0,       duration: 1.05, stagger: 0.13, ease: 'power4.out' }, '-=0.3')
      .to('.hero-sub',  { opacity: 1, duration: 0.72, ease: 'power3.out' }, '-=0.5')
      .to('.hero-cta',  { opacity: 1, duration: 0.6,  ease: 'power3.out' }, '-=0.42');
  } else {
    gsap.set('.hero-line', { y: 0 });
    gsap.set('.hero-pre, .hero-sub, .hero-cta', { opacity: 1 });
  }

  /* ══════════════════════════════════════════════════════════════
     3. SCROLL ANIMATIONS
     ══════════════════════════════════════════════════════════════ */
  if (!isReduced) {

    /* Bento tiles – staggered fade-in-up */
    ScrollTrigger.batch('.gsap-card', {
      onEnter: (els) => gsap.to(els, {
        opacity: 1, y: 0,
        duration: 0.65, stagger: 0.1,
        ease: 'power3.out',
      }),
      once:  true,
      start: 'top 88%',
    });

    /* ── GSAP counter for stats (counts up from 0 on scroll) ─── */
    document.querySelectorAll<HTMLElement>('.counter-el').forEach((el) => {
      const target = parseInt(el.dataset.target ?? '0', 10);
      const suffix = el.dataset.suffix ?? '';
      const obj    = { val: 0 };

      ScrollTrigger.create({
        trigger: el,
        start:   'top 85%',
        once:    true,
        onEnter: () => {
          gsap.to(obj, {
            val:      target,
            duration: 2,
            ease:     'power2.out',
            onUpdate: () => {
              el.textContent = Math.round(obj.val).toLocaleString('nb-NO') + suffix;
            },
          });
        },
      });
    });

    /* ── TIMELINE: directional slide-in from each side ───────── */
    document.querySelectorAll<HTMLElement>('.timeline-item').forEach((item) => {
      const isLeft = item.classList.contains('tl-left');
      /* Mobile: pure fade+scale (no x-offset to avoid overflow) */
      const xFrom = isMobile ? 0 : (isLeft ? -55 : 55);

      gsap.fromTo(item,
        { opacity: 0, x: xFrom, scale: 0.92 },
        {
          opacity: 1, x: 0, scale: 1,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: item,
            start:   'top 92%',
            end:     'top 38%',
            scrub:   1.3,
          },
        }
      );
    });

  } else {
    gsap.set('.gsap-card', { opacity: 1, y: 0 });
    gsap.set('.timeline-item', { opacity: 1, x: 0, scale: 1 });
  }

  /* ══════════════════════════════════════════════════════════════
     4. NEWS SECTION — solid background fade + sine-wave particles
        Background: rgba(83,127,143) fades in via IntersectionObserver.
        Particles: drift upward in sine waves (cyan), turn orange + vibrate
        when near the card closest to viewport centre (heat atoms).
        Desktop only — touch devices skip canvas.
     ══════════════════════════════════════════════════════════════ */
  const newsBg      = document.getElementById('news-bg')        as HTMLElement      | null;
  const newsCanvas  = document.getElementById('news-particles')  as HTMLCanvasElement| null;
  const newsSection = document.getElementById('news')            as HTMLElement      | null;

  if (newsBg && newsSection) {
    /* Fade the solid background in when section enters viewport */
    new IntersectionObserver(
      ([e]) => { newsBg.style.opacity = e.isIntersecting ? '1' : '0'; },
      { threshold: 0.08 }
    ).observe(newsSection);
  }

  if (newsCanvas && newsSection && !isTouch && !isReduced) {

    /* Size canvas to match section */
    newsCanvas.width  = newsSection.offsetWidth;
    newsCanvas.height = newsSection.offsetHeight;
    const ctx = newsCanvas.getContext('2d')!;
    const W   = newsCanvas.width;
    const H   = newsCanvas.height;

    interface NewsParticle {
      baseX: number; y: number;
      size: number; speed: number; opacity: number;
      phase: number; freq: number; amplitude: number;
      color: number;   // 0 = cyan, 1 = orange (smoothly animated)
      vibPhase: number;
    }

    const COUNT = 72;
    const pts: NewsParticle[] = Array.from({ length: COUNT }, () => ({
      baseX:     Math.random() * W,
      y:         Math.random() * H,
      size:      Math.random() * 1.7 + 0.7,
      speed:     Math.random() * 0.38 + 0.14,
      opacity:   Math.random() * 0.45 + 0.18,
      phase:     Math.random() * Math.PI * 2,
      freq:      Math.random() * 0.008 + 0.003,
      amplitude: Math.random() * 22 + 8,
      color:     0,
      vibPhase:  0,
    }));

    /* Cache focused card position — updated on scroll, not per frame */
    const cards = Array.from(newsSection.querySelectorAll<HTMLElement>('.tl-card'));
    let focusedY: number | null = null;
    let focusedHalf = 0;

    function updateFocused() {
      const secTop  = newsSection!.getBoundingClientRect().top;
      const viewMid = window.innerHeight / 2;
      let best: Element | null = null;
      let bestD = Infinity;
      cards.forEach(c => {
        const r = c.getBoundingClientRect();
        const d = Math.abs((r.top + r.bottom) / 2 - viewMid);
        if (d < bestD) { bestD = d; best = c; }
      });
      if (best && bestD < window.innerHeight * 0.65) {
        const r = (best as Element).getBoundingClientRect();
        focusedY    = (r.top + r.bottom) / 2 - secTop;
        focusedHalf = r.height / 2 + 90;
      } else {
        focusedY = null;
      }
    }
    window.addEventListener('scroll', updateFocused, { passive: true });
    updateFocused();

    /* Frame loop — throttled to 30 fps */
    const FPS_MS = 1000 / 30;
    let lastTs = 0;
    let rafId: number | null = null;

    function frame(ts: number) {
      rafId = requestAnimationFrame(frame);
      if (ts - lastTs < FPS_MS) return;
      lastTs = ts;

      ctx.clearRect(0, 0, W, H);

      for (const p of pts) {
        const x = p.baseX + p.amplitude * Math.sin(p.freq * p.y + p.phase);

        /* Colour target based on proximity to focused card */
        let target = 0;
        if (focusedY !== null) {
          const d = Math.abs(p.y - focusedY);
          if (d < focusedHalf) target = 1 - d / focusedHalf;
        }
        p.color += (target - p.color) * 0.07;

        /* Vibration — sinusoidal, not random, so it looks intentional */
        p.vibPhase += p.color * 0.45;
        const vx = Math.sin(p.vibPhase * 11 + p.phase) * p.color * 2.8;
        const vy = Math.sin(p.vibPhase *  7             ) * p.color * 1.2;

        /* Interpolate cyan (0,191,255) → eldION orange (233,78,27) */
        const r = Math.round(        p.color * 233);
        const g = Math.round(191 - p.color * 113);
        const b = Math.round(255 - p.color * 228);

        ctx.globalAlpha = p.opacity * (1 + p.color * 0.35);
        ctx.beginPath();
        ctx.arc(x + vx, p.y + vy, p.size * (1 + p.color * 0.4), 0, Math.PI * 2);
        ctx.fillStyle = `rgb(${r},${g},${b})`;
        ctx.fill();
        ctx.globalAlpha = 1;

        p.y -= p.speed;
        if (p.y < -10) { p.y = H + 10; p.baseX = Math.random() * W; }
      }
    }

    /* Pause loop when section is off-screen */
    new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting) { if (!rafId) rafId = requestAnimationFrame(frame); }
        else { if (rafId) { cancelAnimationFrame(rafId); rafId = null; } }
      },
      { rootMargin: '120px 0px' }
    ).observe(newsSection);
  }

  /* ══════════════════════════════════════════════════════════════
     4b. TEAM IMAGES – colour on scroll-into-view (touch/mobile)
         On desktop, CSS group-hover handles grayscale→colour.
         On touch devices hover never fires, so we use
         IntersectionObserver: visible card → full colour,
         out-of-view → grey. CSS transition makes it smooth.
     ══════════════════════════════════════════════════════════════ */
  if (isTouch) {
    const teamObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const img = entry.target as HTMLElement;
          img.style.filter = entry.isIntersecting
            ? 'grayscale(0%)'
            : 'grayscale(100%)';
        });
      },
      { threshold: 0.45, rootMargin: '-8% 0px -8% 0px' }
    );

    document.querySelectorAll<HTMLElement>('.team-img').forEach((img) => {
      teamObs.observe(img);
    });
  }

  /* ══════════════════════════════════════════════════════════════
     5. 3-D TILT ON SOLUTION IMAGES
     ══════════════════════════════════════════════════════════════ */
  if (!isTouch) {
    document.querySelectorAll<HTMLElement>('.tilt-img').forEach((img) => {
      img.style.transformStyle = 'preserve-3d';
      img.style.willChange     = 'transform';
      img.style.transition     = 'box-shadow 0.3s ease';

      img.addEventListener('mousemove', (e: MouseEvent) => {
        const r = img.getBoundingClientRect();
        const x = ((e.clientX - r.left)  / r.width  - 0.5) * 24;
        const y = ((e.clientY - r.top)   / r.height - 0.5) * -24;
        gsap.to(img, {
          rotateX: y, rotateY: x,
          transformPerspective: 700,
          duration: 0.28, ease: 'power2.out',
          boxShadow: `${-x * 0.4}px ${y * 0.4}px 30px rgba(0,174,239,0.2)`,
        });
      });

      img.addEventListener('mouseleave', () => {
        gsap.to(img, {
          rotateX: 0, rotateY: 0,
          boxShadow: 'none',
          duration: 0.55, ease: 'elastic.out(1,0.32)',
        });
      });
    });
  }

  /* ══════════════════════════════════════════════════════════════
     6. PARALLAX ON PRODUCT IMAGES
     ══════════════════════════════════════════════════════════════ */
  if (!isReduced) {
    document.querySelectorAll<HTMLElement>('.parallax-img').forEach((img) => {
      gsap.fromTo(img,
        { y: 55 },
        {
          y: -55,
          ease: 'none',
          scrollTrigger: { trigger: img, start: 'top bottom', end: 'bottom top', scrub: 1 },
        }
      );
    });
  }

  /* ══════════════════════════════════════════════════════════════
     7. MAGNETIC BUTTONS
     ══════════════════════════════════════════════════════════════ */
  if (!isTouch) {
    document.querySelectorAll<HTMLElement>('.magnetic').forEach((btn) => {
      btn.style.willChange = 'transform';

      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const r  = btn.getBoundingClientRect();
        const dx = e.clientX - r.left - r.width  / 2;
        const dy = e.clientY - r.top  - r.height / 2;
        gsap.to(btn, { x: dx * 0.38, y: dy * 0.38, duration: 0.26, ease: 'power2.out' });
      });

      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { x: 0, y: 0, duration: 0.55, ease: 'elastic.out(1,0.35)' });
      });
    });
  }

  /* ══════════════════════════════════════════════════════════════
     8. DECRYPT / SCRAMBLE TEXT
        Usage: add data-decrypt to any element
     ══════════════════════════════════════════════════════════════ */
  const GLYPHS = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz!@#$%^&*+=?><';

  function scramble(el: HTMLElement, original: string, ms = 860) {
    const start = Date.now();
    const id = setInterval(() => {
      const elapsed  = Date.now() - start;
      const progress = Math.min(elapsed / ms, 1);
      const locked   = Math.floor(progress * original.length);

      el.textContent = original
        .split('')
        .map((ch, i) => {
          if (ch === ' ') return ' ';
          return i < locked ? ch : GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
        })
        .join('');

      if (progress >= 1) { el.textContent = original; clearInterval(id); }
    }, 28);
  }

  const decryptObs = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const original = el.dataset.decrypt ?? el.textContent ?? '';
      el.dataset.decrypt = original;
      scramble(el, original);
      decryptObs.unobserve(el);
    });
  }, { threshold: 0.6 });

  document.querySelectorAll<HTMLElement>('[data-decrypt]').forEach((el) => {
    el.dataset.decrypt = el.textContent ?? '';
    decryptObs.observe(el);
  });
</script>
