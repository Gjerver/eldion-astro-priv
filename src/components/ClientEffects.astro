<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const isReduced = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
  const isTouch   = window.matchMedia('(hover:none) and (pointer:coarse)').matches;
  const isMobile  = window.matchMedia('(max-width: 768px)').matches;

  /* ══════════════════════════════════════════════════════════════
     1. INITIAL HIDE – all GSAP-owned elements start invisible
     ══════════════════════════════════════════════════════════════ */
  gsap.set('.gsap-card', { opacity: 0, y: 32 });
  /* .timeline-item opacity:0 is handled by CSS; GSAP fromTo overrides it */

  /* ══════════════════════════════════════════════════════════════
     2. HERO TEXT REVEAL  (load-time, not scroll)
        CSS sets initial hidden state; GSAP animates to visible
     ══════════════════════════════════════════════════════════════ */
  if (!isReduced) {
    const heroTl = gsap.timeline({ delay: 0.22 });
    heroTl
      .to('.hero-pre',  { opacity: 1, duration: 0.6,  ease: 'power3.out' })
      .to('.hero-line', { y: 0,       duration: 1.05, stagger: 0.13, ease: 'power4.out' }, '-=0.3')
      .to('.hero-sub',  { opacity: 1, duration: 0.72, ease: 'power3.out' }, '-=0.5')
      .to('.hero-cta',  { opacity: 1, duration: 0.6,  ease: 'power3.out' }, '-=0.42');
  } else {
    gsap.set('.hero-line', { y: 0 });
    gsap.set('.hero-pre, .hero-sub, .hero-cta', { opacity: 1 });
  }

  /* ══════════════════════════════════════════════════════════════
     3. SCROLL ANIMATIONS
     ══════════════════════════════════════════════════════════════ */
  if (!isReduced) {

    /* Bento tiles – staggered fade-in-up */
    ScrollTrigger.batch('.gsap-card', {
      onEnter: (els) => gsap.to(els, {
        opacity: 1, y: 0,
        duration: 0.65, stagger: 0.1,
        ease: 'power3.out',
      }),
      once:  true,
      start: 'top 88%',
    });

    /* ── GSAP counter for stats (counts up from 0 on scroll) ─── */
    document.querySelectorAll<HTMLElement>('.counter-el').forEach((el) => {
      const target = parseInt(el.dataset.target ?? '0', 10);
      const suffix = el.dataset.suffix ?? '';
      const obj    = { val: 0 };

      ScrollTrigger.create({
        trigger: el,
        start:   'top 85%',
        once:    true,
        onEnter: () => {
          gsap.to(obj, {
            val:      target,
            duration: 2,
            ease:     'power2.out',
            onUpdate: () => {
              el.textContent = Math.round(obj.val).toLocaleString('nb-NO') + suffix;
            },
          });
        },
      });
    });

    /* ── TIMELINE: directional slide-in from each side ───────── */
    document.querySelectorAll<HTMLElement>('.timeline-item').forEach((item) => {
      const isLeft = item.classList.contains('tl-left');
      /* Mobile: pure fade+scale (no x-offset to avoid overflow) */
      const xFrom = isMobile ? 0 : (isLeft ? -55 : 55);

      gsap.fromTo(item,
        { opacity: 0, x: xFrom, scale: 0.92 },
        {
          opacity: 1, x: 0, scale: 1,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: item,
            start:   'top 92%',
            end:     'top 38%',
            scrub:   1.3,
          },
        }
      );
    });

  } else {
    gsap.set('.gsap-card', { opacity: 1, y: 0 });
    gsap.set('.timeline-item', { opacity: 1, x: 0, scale: 1 });
  }

  /* ══════════════════════════════════════════════════════════════
     4. TIMELINE PARTICLE STREAM  (canvas on center line)
        Particles drift UPWARD — time flows toward the present.
        Scrolling down = going back in time.
     ══════════════════════════════════════════════════════════════ */
  const tlCanvas = document.getElementById('tl-stream') as HTMLCanvasElement | null;

  if (tlCanvas && !isReduced && !isTouch) {
    const parent = tlCanvas.parentElement as HTMLElement;

    /* Size the canvas buffer to match the container */
    const containerH = parent.offsetHeight;
    tlCanvas.width  = 24;
    tlCanvas.height = containerH;
    tlCanvas.style.height = containerH + 'px';

    const ctx   = tlCanvas.getContext('2d')!;
    const CX    = 12; // horizontal centre of the 24px canvas

    interface Particle {
      y: number;
      size: number;
      speed: number;
      opacity: number;
      trail: number[];
    }

    const COUNT = 14; // reduced from 22
    const particles: Particle[] = Array.from({ length: COUNT }, () => ({
      y:       Math.random() * containerH,
      size:    Math.random() * 1.8 + 0.6,
      speed:   Math.random() * 0.55 + 0.18,
      opacity: Math.random() * 0.42 + 0.08,
      trail:   [],
    }));

    /* Cache the static center-line gradient — no need to recreate every frame */
    const lineGrad = ctx.createLinearGradient(0, 0, 0, containerH);
    lineGrad.addColorStop(0,    'rgba(0, 174, 239, 0.55)');
    lineGrad.addColorStop(0.35, 'rgba(0, 174, 239, 0.28)');
    lineGrad.addColorStop(0.7,  'rgba(0, 100, 160, 0.14)');
    lineGrad.addColorStop(1,    'rgba(0,  60, 100, 0.05)');

    /* Throttle canvas to 30 fps — background animation doesn't need 60 */
    const FRAME_MS = 1000 / 30;
    let lastFrameTs = 0;
    let rafId: number | null = null;

    function frame(ts: number) {
      rafId = requestAnimationFrame(frame);

      if (ts - lastFrameTs < FRAME_MS) return; // skip frame
      lastFrameTs = ts;

      ctx.clearRect(0, 0, 24, containerH);

      /* Center line (cached gradient, no new object) */
      ctx.beginPath();
      ctx.moveTo(CX, 0);
      ctx.lineTo(CX, containerH);
      ctx.strokeStyle = lineGrad;
      ctx.lineWidth   = 1.5;
      ctx.stroke();

      /* Particles */
      for (const p of particles) {
        /* Trailing tail — simple filled circles, no gradient objects */
        for (let i = p.trail.length - 1; i >= 0; i--) {
          const age  = p.trail.length - i;
          const fade = 1 - age / p.trail.length;
          const r    = p.size * 0.65 * fade;
          if (r < 0.1) continue;
          ctx.globalAlpha = p.opacity * 0.35 * fade;
          ctx.beginPath();
          ctx.arc(CX, p.trail[i], r, 0, Math.PI * 2);
          ctx.fillStyle = '#00BFFF';
          ctx.fill();
        }

        /* Core — solid circle, no createRadialGradient per frame */
        ctx.globalAlpha = Math.min(p.opacity * 1.3, 0.9);
        ctx.beginPath();
        ctx.arc(CX, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = '#78E6FF';
        ctx.fill();

        ctx.globalAlpha = 1; // reset

        /* Update — shorter trail (6 instead of 10) */
        p.trail.push(p.y);
        if (p.trail.length > 6) p.trail.shift();
        p.y -= p.speed;
        if (p.y < -8) { p.y = containerH + 8; p.trail = []; }
      }
    }

    /* Only run the loop while the timeline section is in the viewport.
       100px margin so animation is already going when it scrolls in. */
    const canvasObs = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          if (!rafId) rafId = requestAnimationFrame(frame);
        } else {
          if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
        }
      },
      { rootMargin: '100px 0px' }
    );
    canvasObs.observe(tlCanvas);
  }

  /* ══════════════════════════════════════════════════════════════
     4b. TEAM IMAGES – colour on scroll-into-view (touch/mobile)
         On desktop, CSS group-hover handles grayscale→colour.
         On touch devices hover never fires, so we use
         IntersectionObserver: visible card → full colour,
         out-of-view → grey. CSS transition makes it smooth.
     ══════════════════════════════════════════════════════════════ */
  if (isTouch) {
    const teamObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const img = entry.target as HTMLElement;
          img.style.filter = entry.isIntersecting
            ? 'grayscale(0%)'
            : 'grayscale(100%)';
        });
      },
      { threshold: 0.45, rootMargin: '-8% 0px -8% 0px' }
    );

    document.querySelectorAll<HTMLElement>('.team-img').forEach((img) => {
      teamObs.observe(img);
    });
  }

  /* ══════════════════════════════════════════════════════════════
     5. 3-D TILT ON SOLUTION IMAGES
     ══════════════════════════════════════════════════════════════ */
  if (!isTouch) {
    document.querySelectorAll<HTMLElement>('.tilt-img').forEach((img) => {
      img.style.transformStyle = 'preserve-3d';
      img.style.willChange     = 'transform';
      img.style.transition     = 'box-shadow 0.3s ease';

      img.addEventListener('mousemove', (e: MouseEvent) => {
        const r = img.getBoundingClientRect();
        const x = ((e.clientX - r.left)  / r.width  - 0.5) * 24;
        const y = ((e.clientY - r.top)   / r.height - 0.5) * -24;
        gsap.to(img, {
          rotateX: y, rotateY: x,
          transformPerspective: 700,
          duration: 0.28, ease: 'power2.out',
          boxShadow: `${-x * 0.4}px ${y * 0.4}px 30px rgba(0,174,239,0.2)`,
        });
      });

      img.addEventListener('mouseleave', () => {
        gsap.to(img, {
          rotateX: 0, rotateY: 0,
          boxShadow: 'none',
          duration: 0.55, ease: 'elastic.out(1,0.32)',
        });
      });
    });
  }

  /* ══════════════════════════════════════════════════════════════
     6. PARALLAX ON PRODUCT IMAGES
     ══════════════════════════════════════════════════════════════ */
  if (!isReduced) {
    document.querySelectorAll<HTMLElement>('.parallax-img').forEach((img) => {
      gsap.fromTo(img,
        { y: 55 },
        {
          y: -55,
          ease: 'none',
          scrollTrigger: { trigger: img, start: 'top bottom', end: 'bottom top', scrub: 1 },
        }
      );
    });
  }

  /* ══════════════════════════════════════════════════════════════
     7. MAGNETIC BUTTONS
     ══════════════════════════════════════════════════════════════ */
  if (!isTouch) {
    document.querySelectorAll<HTMLElement>('.magnetic').forEach((btn) => {
      btn.style.willChange = 'transform';

      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const r  = btn.getBoundingClientRect();
        const dx = e.clientX - r.left - r.width  / 2;
        const dy = e.clientY - r.top  - r.height / 2;
        gsap.to(btn, { x: dx * 0.38, y: dy * 0.38, duration: 0.26, ease: 'power2.out' });
      });

      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { x: 0, y: 0, duration: 0.55, ease: 'elastic.out(1,0.35)' });
      });
    });
  }

  /* ══════════════════════════════════════════════════════════════
     8. DECRYPT / SCRAMBLE TEXT
        Usage: add data-decrypt to any element
     ══════════════════════════════════════════════════════════════ */
  const GLYPHS = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz!@#$%^&*+=?><';

  function scramble(el: HTMLElement, original: string, ms = 860) {
    const start = Date.now();
    const id = setInterval(() => {
      const elapsed  = Date.now() - start;
      const progress = Math.min(elapsed / ms, 1);
      const locked   = Math.floor(progress * original.length);

      el.textContent = original
        .split('')
        .map((ch, i) => {
          if (ch === ' ') return ' ';
          return i < locked ? ch : GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
        })
        .join('');

      if (progress >= 1) { el.textContent = original; clearInterval(id); }
    }, 28);
  }

  const decryptObs = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const original = el.dataset.decrypt ?? el.textContent ?? '';
      el.dataset.decrypt = original;
      scramble(el, original);
      decryptObs.unobserve(el);
    });
  }, { threshold: 0.6 });

  document.querySelectorAll<HTMLElement>('[data-decrypt]').forEach((el) => {
    el.dataset.decrypt = el.textContent ?? '';
    decryptObs.observe(el);
  });
</script>
