---
interface Props {
  icon: string;
  title: string;
  description: string;
}
const { icon, title, description } = Astro.props;
---
<div class="flex gap-[15px] mb-[25px] text-left">
  <div class="min-w-[45px] h-[45px] rounded-full border border-eldion-cyan bg-[rgba(0,174,239,0.1)] flex items-center justify-center text-eldion-cyan flex-shrink-0">
    <i data-lucide={icon}></i>
  </div>
  <div>
    <strong class="text-white text-[1.05rem]">{title}</strong>
    <br />
    <span class="text-gray-300 text-sm leading-relaxed" set:html={description} />
  </div>
</div>
