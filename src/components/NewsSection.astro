---
import TimelineItem from './TimelineItem.astro';
import { events } from '../data/timeline';
---
<section id="news" class="pt-[140px] pb-[80px] max-[768px]:pt-[180px] relative overflow-hidden">

  <!-- Solid background — fades in on scroll, hides video so backdrop-filter is cheap -->
  <div id="news-bg" aria-hidden="true"
       style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(61,91,101,0) 0%,#3d5b65 160px,#3d5b65 calc(100% - 130px),rgba(61,91,101,0) 100%);opacity:0;transition:opacity 1.1s ease;pointer-events:none;z-index:0;"></div>

  <!-- Particle canvas (desktop only, driven by JS) -->
  <canvas id="news-particles" aria-hidden="true"
          style="position:absolute;inset:0;pointer-events:none;z-index:1;"></canvas>

  <!-- All content above bg + canvas -->
  <div style="position:relative;z-index:2;">

    <h2 data-animate class="font-comfortaa text-[2em] text-center mb-3">
      <span data-i18n="no">Vår tidslinje</span><span data-i18n="en">Our timeline</span>
    </h2>
    <p data-animate class="text-center text-white/35 text-sm mb-[60px] tracking-wide">
      <span data-i18n="no">Scroll ned for å gå tilbake i tid ↓</span><span data-i18n="en">Scroll down to travel back in time ↓</span>
    </p>

    <div class="timeline-container">
      <div class="timeline-track" aria-hidden="true"></div>

      {events.map((event, index) => (
        <TimelineItem
          date={event.date}
          dateEn={event.dateEn}
          logo={event.logo}
          logoAlt={event.logoAlt}
          title={event.title}
          titleEn={event.titleEn}
          content={event.content}
          contentEn={event.contentEn}
          logoStyle={event.logoStyle}
          side={index % 2 === 0 ? 'left' : 'right'}
        />
      ))}
    </div>

  </div>
</section>
