---
---
<section id="goal" class="pt-28 pb-20 px-4 md:px-[5vw]">
  <div class="max-w-[900px] mx-auto">

    <!-- Header -->
    <p data-animate class="text-eldion-cyan text-[0.7rem] uppercase tracking-[0.24em] font-semibold mb-3">
      Fremtidens Målinger
    </p>
    <h2 data-animate class="font-comfortaa text-[1.9em] text-white mb-16">Vår løsning</h2>

    <!-- ── 2-col: description text + editorial product image ───── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-14 md:gap-20 items-center mb-20">

      <div data-animate class="space-y-5">
        <p class="text-white/58 text-[1rem] leading-[1.8]">
          En sentral målsetning for Industri 4.0 er heldekkende trådløs overvåking, men
          infrastrukturen henger etter. Kabling koster opp mot
          <strong class="text-white font-semibold">1 200 kr/m</strong>
          og er en hyppig feilkilde.
        </p>
        <p class="text-white/58 text-[1rem] leading-[1.8]">
          eldION utnytter tapt spillvarme via termoelektrisk effekt —
          <strong class="text-white font-semibold">uten batterier, uten kabler</strong>.
        </p>
      </div>

      <div data-animate class="flex flex-col items-center">
        <img
          src="/images/skisse3.png"
          alt="eldION skisse"
          class="tilt-img parallax-img w-full max-w-[400px] mix-blend-multiply"
        />
        <p class="text-white/20 text-[0.68rem] mt-3 tracking-wide">Plug &amp; Play — ingen driftsstans</p>
      </div>

    </div>

    <!-- ── Stats row: horizontal, minimal, counter animation ───── -->
    <div data-animate class="border-t border-b border-white/[0.07] py-10">
      <div class="grid grid-cols-3 divide-x divide-white/[0.07]">

        <div class="px-4 md:px-10 text-center">
          <p class="font-inter font-semibold text-white text-2xl tracking-tight leading-none">
            <span class="counter-el" data-target="1200" data-suffix=" kr">0 kr</span><sup class="text-eldion-cyan/70 ml-0.5 text-xs">1</sup>
          </p>
          <p class="text-white/28 text-[0.62rem] uppercase tracking-[0.16em] mt-3 leading-snug">
            per meter<br />kabling spart
          </p>
        </div>

        <div class="px-4 md:px-10 text-center">
          <p class="font-inter font-semibold text-white text-2xl tracking-tight leading-none">
            <span class="counter-el" data-target="100" data-suffix=" kg CO₂">0 kg</span><sup class="text-eldion-cyan/70 ml-0.5 text-xs">2</sup>
          </p>
          <p class="text-white/28 text-[0.62rem] uppercase tracking-[0.16em] mt-3 leading-snug">
            spart per<br />installasjon
          </p>
        </div>

        <div class="px-4 md:px-10 text-center">
          <p class="font-inter font-semibold text-white text-2xl tracking-tight leading-none">
            &lt;1 sek<sup class="text-eldion-cyan/70 ml-0.5 text-xs">3</sup>
          </p>
          <p class="text-white/28 text-[0.62rem] uppercase tracking-[0.16em] mt-3 leading-snug">
            sanntids<br />oppdatering
          </p>
        </div>

      </div>
    </div>

    <!-- ── Technical specs: Apple product-page style ─────────── -->
    <div data-animate class="mt-16 mb-16">
      <p class="text-white/22 text-[0.67rem] uppercase tracking-[0.24em] mb-5">Tekniske Data</p>
      <div class="divide-y divide-white/[0.06]">

        <div class="flex items-start justify-between gap-8 py-[14px]">
          <span class="text-white/32 text-sm min-w-[148px] flex-shrink-0">Temperaturområde</span>
          <span class="text-white/75 text-sm font-medium text-right" data-decrypt>
            Overflate 30–250 °C · Omgivelse −20–50 °C
          </span>
        </div>

        <div class="flex items-start justify-between gap-8 py-[14px]">
          <span class="text-white/32 text-sm min-w-[148px] flex-shrink-0">Effekt ut</span>
          <span class="text-white/75 text-sm font-medium" data-decrypt>
            Testet opp til 868 mW
          </span>
        </div>

        <div class="flex items-start justify-between gap-8 py-[14px]">
          <span class="text-white/32 text-sm min-w-[148px] flex-shrink-0">Kommunikasjon</span>
          <span class="text-white/75 text-sm font-medium" data-decrypt>
            LoRaWAN · WirelessHART · ISA100.11a · BLE
          </span>
        </div>

        <div class="flex items-start justify-between gap-8 py-[14px]">
          <span class="text-white/32 text-sm min-w-[148px] flex-shrink-0">Montering</span>
          <span class="text-white/75 text-sm font-medium" data-decrypt>
            Clamp-on eller magnetisk · Ingen prosessinngrep
          </span>
        </div>

      </div>
    </div>

    <!-- ── Mounting image + CTA ────────────────────────────────── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-14 md:gap-16 items-center mt-4">

      <div data-animate class="text-center">
        <img
          src="/images/montering.png"
          alt="Montering"
          class="tilt-img parallax-img max-w-[300px] w-full mx-auto rounded-3xl
                 shadow-[0_24px_64px_rgba(0,0,0,0.52)] opacity-85"
        />
        <p class="text-white/20 text-[0.68rem] mt-3 tracking-wide">Fleksibel overflatemontering</p>
      </div>

      <div data-animate>
        <p class="text-white/22 text-[0.67rem] uppercase tracking-[0.24em] mb-4">Pilot-partner</p>
        <p class="text-white/55 text-[1rem] leading-[1.78] mb-8">
          Vi søker innovative partnere for pilottesting. Alt vi trenger er en
          ΔT&nbsp;&gt;&nbsp;30°C. Vi tilbyr gratis installasjon og utstyr.
        </p>
        <a
          href="mailto:kontakt@eldion.no"
          class="magnetic inline-flex items-center gap-3 text-white/75 text-sm font-medium
                 border border-white/18 px-7 py-3.5 rounded-full
                 transition-all duration-300
                 hover:border-white/38 hover:bg-white/[0.04] hover:text-white"
        >
          Ta kontakt →
        </a>
      </div>

    </div>

    <!-- ── Footnotes ──────────────────────────────────────────── -->
    <div class="mt-14 pt-5 border-t border-white/[0.05] space-y-1.5">
      <p class="text-white/22 text-[0.6rem] leading-relaxed">
        <sup class="text-white/35 mr-0.5">1</sup> En typisk kabelinstallasjon i industrien har en total kostnad på 800–1 200 kr per meter kabel installert.
      </p>
      <p class="text-white/22 text-[0.6rem] leading-relaxed">
        <sup class="text-white/35 mr-0.5">2</sup> En typisk installasjon på 60 meter instrumentkabel vil kreve 100 kg CO₂, kun i materiale til kabelen.
      </p>
      <p class="text-white/22 text-[0.6rem] leading-relaxed">
        <sup class="text-white/35 mr-0.5">3</sup> Oppdateringsfrekvens er avhengig av temperaturdifferansen.
      </p>
    </div>

  </div>
</section>
