---
/*
  Language switcher — Norwegian / English flag toggle.
  Active language is driven by `data-lang` on <html> (default "no").
  The actual toggle logic lives in BaseLayout (global, runs once).
*/
---
<div class="lang-switch" role="group" aria-label="Språk / Language">
  <button type="button" data-set-lang="no" class="lang-btn" aria-label="Norsk" title="Norsk">
    <svg viewBox="0 0 22 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect width="22" height="16" fill="#ba0c2f" />
      <rect x="6" width="4" height="16" fill="#fff" />
      <rect y="6" width="22" height="4" fill="#fff" />
      <rect x="7" width="2" height="16" fill="#00205b" />
      <rect y="7" width="22" height="2" fill="#00205b" />
    </svg>
  </button>
  <button type="button" data-set-lang="en" class="lang-btn" aria-label="English" title="English">
    <svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <clipPath id="ukflagclip"><rect width="60" height="30" /></clipPath>
      <g clip-path="url(#ukflagclip)">
        <rect width="60" height="30" fill="#012169" />
        <path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6" />
        <path d="M0,0 L60,30 M60,0 L0,30" stroke="#c8102e" stroke-width="4" />
        <rect x="25" width="10" height="30" fill="#fff" />
        <rect y="10" width="60" height="10" fill="#fff" />
        <rect x="27" width="6" height="30" fill="#c8102e" />
        <rect y="12" width="60" height="6" fill="#c8102e" />
      </g>
    </svg>
  </button>
</div>
