---
---
<!-- Particle canvas: z-index -1, replaces the static background image -->
<canvas id="bg-canvas" style="position:fixed;inset:0;width:100%;height:100%;z-index:-1;background:#050508;"></canvas>
<!-- Cursor trail canvas: above everything, pointer-events:none -->
<canvas id="cursor-canvas" style="position:fixed;inset:0;width:100%;height:100%;z-index:9998;pointer-events:none;"></canvas>

<script>
  const isTouch   = window.matchMedia('(hover:none) and (pointer:coarse)').matches;
  const isReduced = window.matchMedia('(prefers-reduced-motion:reduce)').matches;

  const bgEl  = document.getElementById('bg-canvas')     as HTMLCanvasElement;
  const curEl = document.getElementById('cursor-canvas') as HTMLCanvasElement;
  const bgCtx  = bgEl.getContext('2d')!;
  const curCtx = curEl.getContext('2d')!;

  let mouseX = -999, mouseY = -999;

  function resize() {
    bgEl.width  = curEl.width  = window.innerWidth;
    bgEl.height = curEl.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize, { passive: true });

  if (!isTouch) {
    window.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; }, { passive: true });
  }

  /* ─────────────────────────────── PARTICLES ───────────────────────────── */

  class Particle {
    x = 0; y = 0; vx = 0; vy = 0; size = 0;
    opacity = 0; maxOp = 0; life = 0; maxLife = 0;
    heat = 0; wobble = 0;

    constructor(spread = false) { this.reset(spread); }

    reset(spread = false) {
      this.x       = Math.random() * bgEl.width;
      this.y       = spread ? Math.random() * bgEl.height : bgEl.height + Math.random() * 60;
      this.vx      = (Math.random() - 0.5) * 0.45;
      this.vy      = -(Math.random() * 0.85 + 0.28);
      this.size    = Math.random() * 2.2 + 0.4;
      this.maxOp   = Math.random() * 0.48 + 0.08;
      this.opacity = spread ? Math.random() * this.maxOp : 0;
      this.life    = spread ? Math.floor(Math.random() * 250) : 0;
      this.maxLife = Math.random() * 380 + 160;
      this.heat    = 0;
      this.wobble  = Math.random() * Math.PI * 2;
    }

    update() {
      this.life++;
      this.x += this.vx + Math.sin(this.wobble + this.life * 0.018) * 0.22;
      this.y += this.vy;
      this.wobble += 0.003;

      const r = this.life / this.maxLife;
      if      (r < 0.12) this.opacity = this.maxOp * (r / 0.12);
      else if (r > 0.72) this.opacity = this.maxOp * ((1 - r) / 0.28);
      else               this.opacity = this.maxOp;

      /* Mouse heat interaction */
      const dx = mouseX - this.x;
      const dy = mouseY - this.y;
      const d  = Math.sqrt(dx * dx + dy * dy);
      if (d < 160 && mouseX > -900) {
        const f = (1 - d / 160) * 0.55;
        this.vx += (dx / d) * f * 0.022;
        this.vy += (dy / d) * f * 0.022;
        this.heat = Math.min(1, this.heat + 0.1);
      } else {
        this.vy  += (-0.55 - this.vy) * 0.015;
        this.vx  *= 0.97;
        this.heat = Math.max(0, this.heat - 0.022);
      }
      this.vx = Math.max(-1.8, Math.min(1.8, this.vx));
      this.vy = Math.max(-2.6, Math.min(0.6, this.vy));

      if (this.life >= this.maxLife || this.y < -20) this.reset();
    }

    draw() {
      /* Lerp cyan (0,174,239) → orange (233,78,27) */
      const rC = Math.round(0   + this.heat * 233);
      const gC = Math.round(174 - this.heat * 96);
      const bC = Math.round(239 - this.heat * 212);
      const a  = this.opacity;

      bgCtx.beginPath();
      bgCtx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      bgCtx.fillStyle = `rgba(${rC},${gC},${bC},${a})`;
      bgCtx.fill();

      if (this.heat > 0.25) {
        const gr = this.size * (2 + this.heat * 3);
        const grd = bgCtx.createRadialGradient(this.x, this.y, 0, this.x, this.y, gr);
        grd.addColorStop(0, `rgba(${rC},${gC},${bC},${a * this.heat * 0.35})`);
        grd.addColorStop(1, 'transparent');
        bgCtx.beginPath();
        bgCtx.arc(this.x, this.y, gr, 0, Math.PI * 2);
        bgCtx.fillStyle = grd;
        bgCtx.fill();
      }
    }
  }

  /* ─────────────────────────────── CURSOR TRAIL ──────────────────────── */

  interface Pt { x: number; y: number; life: number; size: number; }
  const trail: Pt[] = [];
  if (!isTouch) {
    window.addEventListener('mousemove', (e) => {
      trail.push({ x: e.clientX, y: e.clientY, life: 1, size: 5 + Math.random() * 3 });
      if (trail.length > 55) trail.shift();
    }, { passive: true });
  }

  /* ─────────────────────────────── RENDER LOOP ───────────────────────── */

  if (!isReduced) {
    const COUNT = isTouch ? 0 : Math.min(130, (navigator.hardwareConcurrency ?? 4) * 16);
    const particles = Array.from({ length: COUNT }, (_, i) => new Particle(i > 20));

    bgCtx.fillStyle = '#050508';
    bgCtx.fillRect(0, 0, bgEl.width, bgEl.height);

    function loop() {
      /* --- background --- */
      bgCtx.fillStyle = 'rgba(5,5,8,0.22)';
      bgCtx.fillRect(0, 0, bgEl.width, bgEl.height);
      particles.forEach(p => { p.update(); p.draw(); });

      /* --- cursor canvas --- */
      curCtx.clearRect(0, 0, curEl.width, curEl.height);

      if (!isTouch) {
        for (let i = trail.length - 1; i >= 0; i--) {
          const t = trail[i];
          t.life -= 0.045;
          if (t.life <= 0) { trail.splice(i, 1); continue; }

          const r  = Math.round(233 * t.life);
          const g  = Math.round(78  * t.life + 174 * (1 - t.life));
          const b  = Math.round(27  * t.life + 239 * (1 - t.life));
          const rad = t.size * (1 + (1 - t.life) * 1.6);

          const grd = curCtx.createRadialGradient(t.x, t.y, 0, t.x, t.y, rad);
          grd.addColorStop(0, `rgba(${r},${g},${b},${t.life * 0.58})`);
          grd.addColorStop(1, 'transparent');
          curCtx.beginPath();
          curCtx.arc(t.x, t.y, rad, 0, Math.PI * 2);
          curCtx.fillStyle = grd;
          curCtx.fill();
        }

        /* Main cursor dot */
        if (mouseX > -900) {
          const grd = curCtx.createRadialGradient(mouseX, mouseY, 0, mouseX, mouseY, 18);
          grd.addColorStop(0,    'rgba(255,145,65,0.92)');
          grd.addColorStop(0.38, 'rgba(233,78,27,0.5)');
          grd.addColorStop(1,    'transparent');
          curCtx.beginPath();
          curCtx.arc(mouseX, mouseY, 18, 0, Math.PI * 2);
          curCtx.fillStyle = grd;
          curCtx.fill();

          curCtx.beginPath();
          curCtx.arc(mouseX, mouseY, 3, 0, Math.PI * 2);
          curCtx.fillStyle = 'rgba(255,210,160,0.98)';
          curCtx.fill();
        }
      }

      requestAnimationFrame(loop);
    }

    loop();
  } else {
    /* Reduced motion: plain dark background */
    bgCtx.fillStyle = '#050508';
    bgCtx.fillRect(0, 0, bgEl.width, bgEl.height);
  }
</script>
